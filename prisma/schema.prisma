generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

enum RecordStatus {
  active
  inactive
}

enum PaymentMethod {
  paystack
  bank_transfer
}

enum PaymentStatus {
  pending
  paid
  failed
  abandoned
  awaiting_bank_confirmation
  bank_confirmed
  rejected
  refunded
}

enum OrderStatus {
  pending
  completed
  failed
  rejected
  refunded
}

enum VoucherStatus {
  generated
  delivered
  active
  used
  unused
  expired
  revoked
}

enum DataType {
  limited
  unlimited
}

enum TicketStatus {
  open
  in_progress
  resolved
}

model AdminUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(ADMIN)
  status       RecordStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Hostel {
  id           String          @id @default(cuid())
  name         String          @unique
  address      String?
  wifiSsid     String?
  supportPhone String?
  status       RecordStatus    @default(active)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  plans        HostelPlan[]
  orders       Order[]
  vouchers     Voucher[]
  tickets      SupportTicket[]
}

model Plan {
  id           String       @id @default(cuid())
  name         String
  price        Int
  dataType     DataType
  dataSizeGb   Int?
  validityDays Int
  deviceLimit  Int
  includesTv   Boolean      @default(false)
  description  String?
  badge        String?
  status       RecordStatus @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  hostels      HostelPlan[]
  orders       Order[]
  vouchers     Voucher[]
}

model HostelPlan {
  id        String       @id @default(cuid())
  hostelId  String
  planId    String
  status    RecordStatus @default(active)
  hostel    Hostel       @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  plan      Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([hostelId, planId])
}

model Customer {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  email     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  vouchers  Voucher[]

  @@unique([email, phone])
}

model Order {
  id                    String        @id @default(cuid())
  reference             String        @unique
  customerId            String
  hostelId              String
  planId                String
  voucherId             String?       @unique
  fullName              String
  phone                 String
  email                 String
  roomNumber            String
  blockFloor            String?
  amount                Int
  paymentMethod         PaymentMethod
  paymentStatus         PaymentStatus @default(pending)
  orderStatus           OrderStatus   @default(pending)
  paystackReference     String?       @unique
  bankTransferProofUrl  String?
  bankTransferReference String?
  adminNote             String?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  customer              Customer      @relation(fields: [customerId], references: [id])
  hostel                Hostel        @relation(fields: [hostelId], references: [id])
  plan                  Plan          @relation(fields: [planId], references: [id])
  voucher               Voucher?
  paymentLogs           PaymentLog[]
  tickets               SupportTicket[]
}

model Voucher {
  id             String        @id @default(cuid())
  code           String        @unique
  orderId        String        @unique
  customerId     String
  hostelId       String
  planId         String
  status         VoucherStatus @default(generated)
  validityDays   Int
  deviceLimit    Int
  dataSizeGb     Int?
  generatedAt    DateTime      @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  deliveryStatus String        @default("pending")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])
  hostel         Hostel        @relation(fields: [hostelId], references: [id])
  plan           Plan          @relation(fields: [planId], references: [id])
  tickets        SupportTicket[]
}

model PaymentLog {
  id          String   @id @default(cuid())
  orderId     String
  provider    String
  reference   String
  amount      Int
  status      String
  rawResponse Json?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id])
}

model SupportTicket {
  id            String       @id @default(cuid())
  orderId       String?
  voucherId     String?
  hostelId      String?
  fullName      String
  phone         String
  email         String?
  issueType     String
  message       String
  screenshotUrl String?
  status        TicketStatus @default(open)
  adminNote     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  order         Order?       @relation(fields: [orderId], references: [id])
  voucher       Voucher?     @relation(fields: [voucherId], references: [id])
  hostel        Hostel?      @relation(fields: [hostelId], references: [id])
}

model PolicyPage {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id])
}
